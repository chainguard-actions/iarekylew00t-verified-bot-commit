{
  "name": "verified-bot-commit",
  "description": "GitHub Action for creating signed and verified bot commits",
  "version": "2.2.0",
  "author": "Kyle Colantonio",
  "private": true,
  "homepage": "https://github.com/IAreKyleW00t/verified-bot-commit",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IAreKyleW00t/verified-bot-commit.git"
  },
  "bugs": {
    "url": "https://github.com/IAreKyleW00t/verified-bot-commit/issues"
  },
  "keywords": [
    "actions",
    "node",
    "git"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "ci-test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 npx jest",
    "format:write": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "lint": "npx eslint .",
    "package": "npx rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "package:watch": "npm run package -- --watch",
    "test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 npx jest",
    "all": "npm run format:write && npm run lint && npm run test && npm run package"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0",
    "@octokit/core": "^7.0.6",
    "@octokit/plugin-retry": "^8.1.0",
    "@octokit/plugin-throttling": "^11.0.3",
    "minimatch": "^10.2.4"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.3.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jest": "^30.0.0",
    "@types/minimatch": "^6.0.0",
    "@types/mock-fs": "^4.13.4",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "mock-fs": "^5.5.0",
    "prettier": "^3.8.1",
    "rollup": "^4.59.0",
    "ts-jest": "^29.4.6",
    "ts-jest-resolver": "^2.0.1",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*"
  }
}
